extends layout

block content
  .page-header
    h1 Interviews
    form.inline-form(action="/admin/interviews" method="POST")
      input(type="text" name="title" placeholder="New interview title…" required style="margin-bottom:0;width:300px")
      button.btn(type="submit") + Create

  //- ── Embedding Settings ─────────────────────────────────
  .card
    h2 Embedding Settings
    form(action="/admin/settings" method="POST")
      .input-row
        div
          label Embedding Provider
          select(name="embedding_provider")
            option(value="ollama" selected=(settings.embedding_provider === 'ollama')) Ollama (nomic-embed-text)
            option(value="openai" selected=(settings.embedding_provider === 'openai')) OpenAI (text-embedding-3-small)
        div.ollama-url-field
          label Ollama Base URL
          input(type="text" name="ollama_base_url" value=(settings.ollama_base_url || 'http://localhost:11434') placeholder="http://localhost:11434" style="margin-bottom:0")
      button.btn(type="submit" style="margin-top:12px") Save Embedding Settings
    script.
      (function() {
        const sel = document.querySelector('select[name="embedding_provider"]');
        const urlField = document.querySelector('.ollama-url-field');
        function toggle() { urlField.style.display = sel.value === 'ollama' ? '' : 'none'; }
        sel.addEventListener('change', toggle);
        toggle();
      })();

  if interviews && interviews.length
    .interview-grid
      each i in interviews
        .interview-card
          .interview-card-header
            h3= i.title
            span(class=`badge badge-${i.status === 'active' ? 'done' : 'rejected'}`)= i.status
          .interview-card-body
            .stat
              span.stat-value= i.candidate_count || 0
              span.stat-label Candidates
            .stat
              span.stat-value= i.pass_threshold
              span.stat-label Threshold
            p.date= i.created_at ? new Date(i.created_at).toLocaleDateString() : ''
          .interview-card-footer
            a.btn-sm.btn-invite(href=`/admin/interviews/${i.id}`) Open →
            form(action=`/admin/interviews/${i.id}/delete-interview` method="POST" style="display:inline" onsubmit="return confirm('Delete this interview and ALL its candidates?')")
              button.btn-sm.btn-delete(type="submit") ✕ Delete
  else
    .card
      p(style="color:var(--text-muted);text-align:center;padding:40px 0") No interviews yet. Create one to get started.
