extends layout-auth

block content
  .auth-container
    .auth-card
      .auth-logo Interview Assistant
      h2 Change Your Password
      p(style="color:var(--text-muted);font-size:13px;text-align:center;margin-bottom:16px") You must set a new password before continuing.
      if error
        .auth-error= error
      form(action="/candidate/change-password" method="POST")
        label New Password
        input(type="password" name="newPassword" required placeholder="Enter new password" minlength="6")
        label Confirm Password
        input(type="password" name="confirmPassword" required placeholder="Confirm new password" minlength="6")
        button.btn(type="submit" style="width:100%") Update Password
