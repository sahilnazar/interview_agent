extends layout-auth

block content
  .auth-container(style="max-width:480px")
    .auth-card(style="text-align:center")
      .auth-logo Interview Assistant

      if decision === 'confirm'
        div(style="font-size:48px;margin:20px 0") ✓
        h2(style="color:var(--success)") Confirmed!
        if role === 'candidate'
          p(style="font-size:14px;color:var(--text-muted);margin-top:12px")
            | Your slot has been reserved. The interviewer will confirm shortly and you'll receive a final confirmation email.
        else
          p(style="font-size:14px;color:var(--text-muted);margin-top:12px")
            | You've confirmed this interview. Both you and the candidate will receive a confirmation email.
        if slot_start
          p(style="margin-top:16px;font-family:'Syne',sans-serif;font-weight:700;color:var(--accent);font-size:16px")
            = new Date(slot_start).toLocaleString('en-US', {weekday:'long',month:'long',day:'numeric',hour:'2-digit',minute:'2-digit'})

      else if decision === 'reject'
        div(style="font-size:48px;margin:20px 0") ✗
        h2(style="color:var(--danger)") Declined
        if role === 'candidate'
          p(style="font-size:14px;color:var(--text-muted);margin-top:12px")
            | You've declined this slot. We'll be in touch with alternative options.
        else
          p(style="font-size:14px;color:var(--text-muted);margin-top:12px")
            | The candidate has been notified and will be offered alternative slots.

      else
        div(style="font-size:48px;margin:20px 0") ℹ
        h2 Already Responded
        p(style="font-size:14px;color:var(--text-muted);margin-top:12px")
          | This slot has already been confirmed or declined.

      p(style="margin-top:28px;font-size:12px;color:var(--text-muted)") You can close this window.
