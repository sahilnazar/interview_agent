extends layout

block content
  .page-header
    a.back-link(href="/admin") ← Back
    h1 Interviewers
    form.inline-form(action="/admin/interviewers" method="POST")
      input(type="text" name="name" placeholder="Full name" required style="width:180px;margin-bottom:0")
      input(type="email" name="email" placeholder="email@company.com" required style="width:200px;margin-bottom:0")
      input(type="text" name="department" placeholder="Department (optional)" style="width:180px;margin-bottom:0")
      button.btn(type="submit") + Add Interviewer

  .card
    if interviewers && interviewers.length
      table
        thead
          tr
            th Name
            th Email
            th Department
            th Interviews
            th Available Slots
            th Actions
        tbody
          each i in interviewers
            tr
              td= i.name
              td= i.email
              td= i.department || '—'
              td= i.assigned_interviews || 0
              td= i.available_slots || 0
              td.actions-cell
                a.btn-sm.btn-invite(href="/interviewer/calendar" target="_blank" title="Open their calendar portal") Calendar ↗
                form(action=`/admin/interviewers/${i.id}/delete` method="POST" style="display:inline"
                     onsubmit="return confirm('Delete this interviewer?')")
                  button.btn-sm.btn-delete(type="submit") ✕ Delete
    else
      p(style="color:var(--text-muted);text-align:center;padding:40px 0")
        | No interviewers yet. Add one above.
