doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title Interview Assistant — Candidate
    link(href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Mono:wght@300;400;500&display=swap" rel="stylesheet")
    style.
      :root {
        --bg: #080810;
        --surface: #0f0f1a;
        --accent: #4f6ef7;
        --accent-hover: #3b5ce4;
        --success: #22c55e;
        --danger: #ef4444;
        --warning: #f59e0b;
        --text: #e2e8f0;
        --text-muted: #94a3b8;
        --border: #1e293b;
        --radius: 10px;
      }
      * { margin: 0; padding: 0; box-sizing: border-box; }
      body {
        font-family: 'DM Mono', monospace;
        background: var(--bg);
        color: var(--text);
        min-height: 100vh;
      }
      h1, h2, h3, h4 { font-family: 'Syne', sans-serif; font-weight: 700; }
      .topbar {
        background: var(--surface);
        border-bottom: 1px solid var(--border);
        padding: 16px 32px;
        display: flex;
        align-items: center;
        justify-content: space-between;
      }
      .topbar .logo {
        font-family: 'Syne', sans-serif;
        font-size: 18px;
        font-weight: 800;
        color: var(--accent);
      }
      .content {
        max-width: 800px;
        margin: 0 auto;
        padding: 40px 24px;
      }
      .card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 28px;
        margin-bottom: 28px;
      }
      .card h2 { margin-bottom: 20px; font-size: 18px; }
      label {
        display: block;
        font-size: 12px;
        color: var(--text-muted);
        margin-bottom: 6px;
        text-transform: uppercase;
        letter-spacing: .5px;
      }
      .btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 10px 22px;
        background: var(--accent);
        color: #fff;
        border: none;
        border-radius: 6px;
        font-family: 'DM Mono', monospace;
        font-size: 13px;
        font-weight: 500;
        cursor: pointer;
        transition: background .15s;
      }
      .btn:hover { background: var(--accent-hover); }
      .btn-sm {
        display: inline-flex; align-items: center; gap: 4px;
        padding: 5px 14px; border: none; border-radius: 5px;
        font-family: 'DM Mono', monospace; font-size: 11px;
        font-weight: 500; cursor: pointer; color: #fff;
        text-decoration: none;
      }
      .btn-delete { background: #64748b; }
      .badge {
        display: inline-block; padding: 3px 10px; border-radius: 20px;
        font-size: 11px; font-weight: 500; text-transform: uppercase; letter-spacing: .3px;
      }
      .badge-screening { background: rgba(79,110,247,.15); color: var(--accent); }
      .badge-awaitingvideo { background: rgba(245,158,11,.15); color: var(--warning); }
      .badge-videoreceived { background: rgba(168,85,247,.15); color: #a855f7; }
      .badge-done { background: rgba(34,197,94,.15); color: var(--success); }
      .badge-rejected { background: rgba(239,68,68,.15); color: var(--danger); }
      .badge-error { background: rgba(239,68,68,.25); color: var(--danger); }
      .score { font-weight: 500; font-family: 'Syne', sans-serif; }
      .match-chip { display:inline-block; padding:2px 8px; background:rgba(34,197,94,.12); color:var(--success); border-radius:4px; font-size:11px; margin:2px; }
      .miss-chip { display:inline-block; padding:2px 8px; background:rgba(239,68,68,.12); color:var(--danger); border-radius:4px; font-size:11px; margin:2px; }
      .page-header { display: flex; align-items: center; gap: 20px; margin-bottom: 32px; }
      .page-header h1 { margin: 0; }
      .status-row { display: flex; gap: 32px; align-items: center; }
      .status-item { display: flex; flex-direction: column; gap: 6px; }
      .status-label { font-size: 12px; color: var(--text-muted); text-transform: uppercase; letter-spacing: .5px; }
      .upload-area { background: var(--bg); border: 1px solid var(--border); border-radius: 6px; padding: 20px; }

  body
    header.topbar
      span.logo Interview Assistant
    main.content
      block content
