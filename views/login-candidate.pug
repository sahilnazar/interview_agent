extends layout-auth

block content
  .auth-container
    .auth-card
      .auth-logo Interview Assistant
      h2 Candidate Login
      if error
        .auth-error= error
      form(action="/login/candidate" method="POST")
        label Email
        input(type="email" name="email" required autofocus placeholder="you@example.com")
        label Login Token
        input(type="text" name="token" required placeholder="Your unique token")
        label Password
        input(type="password" name="password" required placeholder="••••••••")
        button.btn(type="submit" style="width:100%") Sign In
      p.auth-switch
        | Are you an admin? 
        a(href="/login/admin") Login here
