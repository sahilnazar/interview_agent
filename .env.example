# LLM keys
GROQ_API_KEY=gsk_your_groq_api_key
OPENAI_API_KEY=sk-your_openai_api_key       # required — text-embedding-3-small
GOOGLE_API_KEY=your_google_api_key          # optional — needed for video analysis

# PostgreSQL
PGHOST=localhost
PGPORT=5432
